      <column caption='Total BEV Type' datatype='integer' name='[Calculation_0101437157715969]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#13;&#10;if [electric_vehicle_type] = &quot;Battery Electric Vehicle (BEV)&quot;&#13;&#10;then[dol_vehicle_id] &#13;&#10;END&#13;&#10;)' />
      </column>
      <column caption='percentage of vehicles' datatype='real' name='[Calculation_0101437158981634]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0101437157715969]/[Calculation_0101437153210368]' />
      </column>
      <column caption='Total PHEV Vehicles' datatype='integer' name='[Calculation_0101437186232323]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(if [electric_vehicle_type] =&apos;Plug-in Hybrid Electric Vehicle (PHEV)&apos; THEN&#13;&#10;[dol_vehicle_id] END)' />
